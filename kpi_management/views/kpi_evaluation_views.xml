<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_kpi_evaluation_form" model="ir.ui.view">
        <field name="name">kpi.evaluation.form</field>
        <field name="model">kpi.evaluation</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="employee_id"/>
                        <field name="template_id"/>
                        <field name="evaluation_date"/>
                        <field name="total_score" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Score Details">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="skill_line_id" domain="[('template_id', '=', parent.template_id)]"/>
                                    <field name="achieved_score"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_kpi_evaluation" model="ir.actions.act_window">
        <field name="name">KPI Evaluations</field>
        <field name="res_model">kpi.evaluation</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>