<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_kpi_evaluation_form" model="ir.ui.view">
        <field name="name">kpi.evaluation.form</field>
        <field name="model">kpi.evaluation</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="employee_id"/>
                        <field name="template_id"/>
                        <field name="evaluation_date"/>
                        <field name="attendance_score" readonly="1"/>
                        <field name="total_score" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Score Details">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="skill_id" domain="[('id', 'not in', parent.evaluation_skill_ids)]"/>
                                    <field name="achieved_score"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_kpi_evaluation_list" model="ir.ui.view">
        <field name="name">kpi.evaluation.list</field>
        <field name="model">kpi.evaluation</field>
        <field name="arch" type="xml">
            <list>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="template_id"/>
                <field name="evaluation_date"/>
                <field name="total_score"/>
            </list>
        </field>
    </record>

    <record id="view_kpi_evaluation_kanban" model="ir.ui.view">
        <field name="name">kpi.evaluation.kanban</field>
        <field name="model">kpi.evaluation</field>
        <field name="arch" type="xml">
            <kanban>
                <templates>
                    <t t-name="card">
                        <main class="oe_kanban_global_click">
                            <div class="d-flex flex-column">
                                <strong class="o_kanban_record_title">
                                    <field name="employee_id"/>
                                </strong>
                                <div class="text-muted">
                                    <field name="department_id"/>
                                </div>
                                <div class="text-muted">
                                    <field name="template_id"/>
                                </div>
                                <div class="mt-2 text-primary">
                                    <strong>Score: </strong>
                                    <field name="total_score"/>
                                </div>
                                <div class="text-muted">
                                    <field name="evaluation_date"/>
                                </div>
                            </div>
                        </main>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_kpi_evaluation" model="ir.actions.act_window">
        <field name="name">KPI Evaluations</field>
        <field name="res_model">kpi.evaluation</field>
        <field name="view_mode">list,kanban,form</field>
    </record>

    <record id="view_kpi_evaluation_search" model="ir.ui.view">
        <field name="name">kpi.evaluation.search</field>
        <field name="model">kpi.evaluation</field>
        <field name="arch" type="xml">
            <search>
                <field name="employee_id"/>
                <field name="department_id"/>
                <filter string="Department" name="group_by_department" context="{'group_by': 'department_id'}"/>
            </search>
        </field>
    </record>

</odoo>