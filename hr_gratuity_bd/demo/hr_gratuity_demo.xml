<?xml version="1.0" encoding="utf-8"?>
<odoo>
<record id="demo_dept_hr" model="hr.department">
        <field name="name">Human Resources</field>
    </record>

    <record id="demo_dept_it" model="hr.department">
        <field name="name">Information Technology</field>
    </record>

    <record id="demo_dept_finance" model="hr.department">
        <field name="name">Finance &amp; Accounts</field>
    </record>

    <record id="demo_job_manager" model="hr.job">
        <field name="name">Senior Manager</field>
        <field name="department_id" ref="demo_dept_hr"/>
    </record>

    <record id="demo_job_dev" model="hr.job">
        <field name="name">Software Developer</field>
        <field name="department_id" ref="demo_dept_it"/>
    </record>

    <record id="demo_job_accountant" model="hr.job">
        <field name="name">Accountant</field>
        <field name="department_id" ref="demo_dept_finance"/>
    </record>

    <record id="demo_employee_rahela" model="hr.employee">
        <field name="name">Rahela Begum</field>
        <field name="department_id" ref="demo_dept_hr"/>
        <field name="job_id" ref="demo_job_manager"/>
        <field name="date_start">2017-01-15</field>
        <field name="gender">female</field>
    </record>

    <record id="demo_gratuity_rahela" model="hr.gratuity">
        <field name="employee_id" ref="demo_employee_rahela"/>
        <field name="joining_date">2017-01-15</field>
        <field name="departure_date">2025-01-15</field>
        <field name="calculation_date">2025-01-15</field>
        <field name="gross_wage">80000.00</field>
        <field name="basic_percentage">60.0</field>
        <field name="calculation_type">bd_labor_law</field>
        <field name="days_per_year_below_5">30</field>
        <field name="days_per_year_above_5">45</field>
        <field name="working_days_per_month">26</field>
        <field name="min_service_years">1</field>
        <field name="is_nbr_approved">True</field>
        <field name="tax_exemption_limit">25000000.00</field>
        <field name="tax_rate">10.0</field>
        <field name="state">approved</field>
        <field name="notes">Voluntary resignation after completing 8 full years of service. In accordance with Bangladesh Labor Law, a 30 days/year calculation is applied for the first 5 years, and a 45 days/year rate is applied for the remaining 3 years.</field>
    </record>

    <record id="demo_employee_karim" model="hr.employee">
        <field name="name">Md. Karim Uddin</field>
