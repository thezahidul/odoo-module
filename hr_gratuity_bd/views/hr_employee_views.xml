<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_employee_form_gratuity_btn" model="ir.ui.view">
        <field name="name">hr.employee.form.gratuity.button</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_open_gratuity"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-money">
                    <field name="gratuity_count"
                           widget="statinfo"
                           string="Gratuity"/>
                </button>
            </xpath>
        </field>
    </record>

</odoo>