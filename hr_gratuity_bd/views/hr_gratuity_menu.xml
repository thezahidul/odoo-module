<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_hr_gratuity_policy" model="ir.actions.act_window">
        <field name="name">Gratuity Policies</field>
        <field name="res_model">hr.gratuity.policy</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Gratuity Policy Configuration
            </p>
            <p>
                Define corporate gratuity schemas, calculation days, and rounding rules per country or company law.
            </p>
        </field>
    </record>

    <menuitem
        id="menu_hr_gratuity_root"
        name="Gratuity (BD Law)"
        parent="hr.menu_hr_root"
        sequence="25"/>

    <menuitem
        id="menu_hr_gratuity_records"
        name="Gratuity Records"
        parent="menu_hr_gratuity_root"
        action="action_hr_gratuity"
        sequence="10"/>

    <menuitem
        id="menu_hr_gratuity_configuration"
        name="Configuration"
        parent="menu_hr_gratuity_root"
        sequence="90"
        groups="hr.group_hr_manager"/>

    <menuitem
        id="menu_hr_gratuity_policy_records"
        name="Gratuity Policies"
        parent="menu_hr_gratuity_configuration"
        action="action_hr_gratuity_policy"
        sequence="10"/>

    <record id="seq_hr_gratuity" model="ir.sequence">
        <field name="name">HR Gratuity</field>
        <field name="code">hr.gratuity</field>
        <field name="prefix">GRTY/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

</odoo>