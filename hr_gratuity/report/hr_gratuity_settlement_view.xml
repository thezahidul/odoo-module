<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="paperformat_gratuity_a4" model="report.paperformat">
        <field name="name">Gratuity Settlement A4</field>
        <field name="default" eval="True"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">25</field> <field name="margin_bottom">20</field>
        <field name="margin_left">15</field>
        <field name="margin_right">15</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">20</field> <field name="dpi">96</field>
    </record>

    <record id="action_report_gratuity_settlement" model="ir.actions.report">
        <field name="name">Gratuity Settlement Report</field>
        <field name="model">hr.gratuity</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">hr_gratuity_bd.report_gratuity_settlement</field>
        <field name="report_file">hr_gratuity_bd.report_gratuity_settlement</field>
        <field name="print_report_name">'Gratuity_Settlement_%s' % (object.name)</field>
        <field name="paperformat_id" ref="paperformat_gratuity_a4"/>
        <field name="binding_model_id" ref="model_hr_gratuity"/>
        <field name="binding_type">report</field>
    </record>

</odoo>