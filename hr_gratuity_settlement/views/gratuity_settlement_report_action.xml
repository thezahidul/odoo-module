<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Paper Format -->
    <record id="paperformat_gratuity_settlement" model="report.paperformat">
        <field name="name">Gratuity Settlement A4</field>
        <field name="default" eval="True"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">15</field>
        <field name="margin_bottom">15</field>
        <field name="margin_left">15</field>
        <field name="margin_right">15</field>
        <field name="header_line" eval="False"/>
        <field name="dpi">90</field>
    </record>

    <!-- Report Action -->
    <record id="action_report_gratuity_settlement" model="ir.actions.report">
        <field name="name">Gratuity Settlement Report</field>
        <field name="model">hr.gratuity.settlement</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">hr_gratuity_settlement.report_gratuity_settlement_template</field>
        <field name="report_file">hr_gratuity_settlement.report_gratuity_settlement_template</field>
        <field name="binding_model_id" ref="model_hr_gratuity_settlement"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="paperformat_gratuity_settlement"/>
    </record>
</odoo>
