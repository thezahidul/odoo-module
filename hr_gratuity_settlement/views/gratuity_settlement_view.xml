<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View -->
    <record id="gratuity_settlement_list_view" model="ir.ui.view">
        <field name="name">hr.gratuity.settlement.list</field>
        <field name="model">hr.gratuity.settlement</field>
        <field name="arch" type="xml">
            <list string="Gratuity Settlements" decoration-info="state == 'draft'" decoration-success="state == 'paid'" decoration-warning="state == 'approved'">
                <field name="name" string="Settlement #"/>
                <field name="employee_id" string="Employee"/>
                <field name="joining_date"/>
                <field name="resignation_date"/>
                <field name="service_years" string="Years"/>
                <field name="gross_gratuity" widget="monetary"/>
                <field name="net_payable" widget="monetary"/>
                <field name="state" widget="badge" decoration-success="state == 'paid'" decoration-warning="state == 'approved'" decoration-info="state == 'draft'"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="gratuity_settlement_form_view" model="ir.ui.view">
        <field name="name">hr.gratuity.settlement.form</field>
        <field name="model">hr.gratuity.settlement</field>
        <field name="arch" type="xml">
            <form string="Gratuity Settlement">
                <header>
                    <button name="action_submit" string="Submit" type="object" class="btn-primary"/>
                    <button name="action_approve" string="Approve" type="object" class="btn-success" groups="hr.group_hr_manager"/>
                    <button name="action_mark_paid" string="Mark as Paid" type="object" class="btn-info"/>
                    <button name="action_cancel" string="Cancel" type="object"/>
                    <button name="action_reset_to_draft" string="Reset to Draft" type="object" groups="hr.group_hr_manager"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,paid,cancelled"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <!-- Employee Information Section -->
                    <group string="Employee Information">
                        <group>
                            <field name="employee_id" string="Employee" required="1"/>
                            <field name="company_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="joining_date" string="Joining Date"/>
                            <field name="resignation_date" string="Resignation Date"/>
                        </group>
                    </group>

                    <!-- Service Period Calculation -->
                    <group string="Service Period">
                        <group>
                            <field name="service_years" readonly="1" string="Service (Years)"/>
                            <field name="service_days" readonly="1" string="Service (Days)"/>
                        </group>
                        <group>
                            <field name="is_eligible" readonly="1" widget="boolean_toggle" string="Eligible for Gratuity"/>
                            <field name="min_service_years" string="Min. Service Required (Years)"/>
                        </group>
                    </group>

                    <!-- Wage and Slab Information -->
                    <group string="Wage and Slab Calculation">
                        <group>
                            <field name="gross_wage" required="1" widget="monetary" string="Monthly Gross Wage"/>
                            <field name="slab_factor" readonly="1" string="Slab Factor"/>
                        </group>
                    </group>

                    <!-- Tax Configuration -->
                    <group string="Tax Configuration">
                        <group>
                            <field name="is_nbr_approved" widget="boolean_toggle" string="NBR Tax Exemption Approved"/>
                            <field name="gratuity_tax_percent" string="Tax Rate (%)"/>
                        </group>
                        <group>
                            <field name="gratuity_exemption_limit" invisible="not is_nbr_approved" widget="monetary" string="Tax Exemption Limit"/>
                        </group>
                    </group>

                    <!-- Gratuity Calculation Results -->
                    <group string="Gratuity Calculation" colspan="2">
                        <group>
                            <field name="gross_gratuity" readonly="1" widget="monetary" string="Gross Gratuity Amount" decoration-bf="1"/>
                            <field name="taxable_amount" readonly="1" widget="monetary" string="Taxable Portion" decoration-warning="taxable_amount > 0"/>
                        </group>
                        <group>
                            <field name="tax_deduction" readonly="1" widget="monetary" string="Tax Deduction" decoration-danger="tax_deduction > 0"/>
                            <field name="net_payable" readonly="1" widget="monetary" string="Net Payable Amount" decoration-success="1" decoration-bf="1"/>
                        </group>
                    </group>

                    <!-- Additional Notes -->
                    <group string="Notes" colspan="2">
                        <field name="notes" nolabel="1" colspan="2"/>
                    </group>

                    <!-- Timestamps -->
                    <group string="Document Tracking" colspan="2">
                        <group>
                            <field name="create_date" readonly="1" string="Created On"/>
                            <field name="create_uid" readonly="1" string="Created By"/>
                        </group>
                        <group>
                            <field name="write_date" readonly="1" string="Last Modified On"/>
                            <field name="write_uid" readonly="1" string="Last Modified By"/>
                        </group>
                    </group>
                </sheet>

                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="gratuity_settlement_search_view" model="ir.ui.view">
        <field name="name">hr.gratuity.settlement.search</field>
        <field name="model">hr.gratuity.settlement</field>
        <field name="arch" type="xml">
            <search string="Gratuity Settlement">
                <field name="name" string="Settlement #"/>
                <field name="employee_id" string="Employee"/>
                <field name="joining_date"/>
                <field name="resignation_date"/>
                <separator/>
                <filter name="filter_draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="filter_submitted" string="Submitted" domain="[('state', '=', 'submitted')]"/>
                <filter name="filter_approved" string="Approved" domain="[('state', '=', 'approved')]"/>
                <filter name="filter_paid" string="Paid" domain="[('state', '=', 'paid')]"/>
                <filter name="filter_cancelled" string="Cancelled" domain="[('state', '=', 'cancelled')]"/>
                <separator/>
                <filter name="filter_eligible" string="Eligible" domain="[('is_eligible', '=', True)]"/>
                <filter name="filter_ineligible" string="Ineligible" domain="[('is_eligible', '=', False)]"/>
                <separator/>
                <filter name="filter_nbr_approved" string="NBR Approved" domain="[('is_nbr_approved', '=', True)]"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_gratuity_settlement" model="ir.actions.act_window">
        <field name="name">Gratuity Settlements</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">hr.gratuity.settlement</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="gratuity_settlement_search_view"/>
        <field name="context">{"search_default_filter_draft": 1}</field>
    </record>

</odoo>
