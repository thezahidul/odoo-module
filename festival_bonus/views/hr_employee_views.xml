<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_employee_form_inherit_festival" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.festival.bonus</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <!-- sex field এর পরে religion যোগ করো -->
            <xpath expr="//field[@name='sex']" position="after">
                <field name="religion"/>
            </xpath>
        </field>
    </record>
</odoo>