<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_festival_bonus_list" model="ir.ui.view">
        <field name="name">festival.bonus.config.list</field>
        <field name="model">festival.bonus.config</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'confirmed'" decoration-muted="state == 'draft'">
                <field name="name" string="Festival Name"/>
                <field name="bonus_month" string="Month"/>
                <field name="bonus_year" string="Year" widget="char"/>
                <field name="salary_base" string="Salary Base"/>
                <field name="bonus_percentage" string="Bonus %"/>
                <field name="total_bonus" string="Total Bonus"/>
                <field name="state" widget="badge" decoration-success="state == 'confirmed'" decoration-warning="state == 'draft'"/>
            </list>
        </field>
    </record>

    <record id="view_festival_bonus_form" model="ir.ui.view">
        <field name="name">festival.bonus.config.form</field>
        <field name="model">festival.bonus.config</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm_bonus" string="Confirm" type="object" class="btn-primary" invisible="state == 'confirmed'"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object" invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Festival Name..."/>
                        </h1>
                    </div>
                    <group>
                        <group string="Schedule">
                            <field name="bonus_month"/>
                            <field name="bonus_year"/>
                            <field name="min_service_months"/>
                        </group>
                        <group string="Bonus Configuration">
                            <field name="salary_base"/>
                            <field name="bonus_percentage"/>
                            <field name="total_bonus"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Employees">
                            <button name="action_open_bulk_add_wizard" string="➕ Bulk Add Employees" type="object" class="btn-secondary" invisible="state == 'confirmed'"/>
                            <field name="bonus_line_ids">
                                <list editable="bottom" multi_edit="1" decoration-success="is_eligible == True" decoration-danger="is_eligible == False">
                                    <field name="employee_id"/>
                                    <field name="joining_date" class="text-center"/>
                                    <field name="service_months" string="Service (M)" readonly="1" class="text-center"/>
                                    <field name="eligibility_status" string="Eligibility" readonly="1" class="text-center"/>
                                    <field name="is_eligible" column_invisible="1"/>
                                    <field name="salary_base_amount" class="text-end"/>
                                    <field name="bonus_amount" readonly="1" class="text-end"/>
                                </list>
                            </field>
                        </page>
                        <page string="Accounting Settings">
                            <group>
                                <field name="journal_id"/>
                                <field name="expense_account_id"/>
                                <field name="payable_account_id"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_festival_bonus" model="ir.actions.act_window">
        <field name="name">Festival Bonus</field>
        <field name="res_model">festival.bonus.config</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_festival_bonus_root" name="Festival Bonus" sequence="10"/>
    <menuitem id="menu_festival_bonus_config" name="Configurations" parent="menu_festival_bonus_root" action="action_festival_bonus"/>
</odoo>