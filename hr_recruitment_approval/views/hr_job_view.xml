<odoo>
    <record id="view_hr_job_form_inherit_approval" model="ir.ui.view">
        <field name="name">hr.job.form.inherit.approval</field>
        <field name="model">hr.job</field>
        <field name="inherit_id" ref="hr.view_hr_job_form"/>
        <field name="arch" type="xml">

            <!-- 1. Header Buttons & Statusbar -->
            <xpath expr="//header" position="inside">
                <button name="action_submit_first" string="Submit to 1st Stage" type="object"
                        invisible="state != 'draft'" class="oe_highlight"/>
                
                <button name="action_approve_second" string="Approve 2nd Stage" type="object"
                        invisible="state != 'first_stage'"
                        groups="hr_recruitment_approval.group_hr_job_approver" class="oe_highlight"/>
                
                <button name="action_approve_final" string="Approve Final Stage" type="object"
                        invisible="state != 'second_stage'"
                        groups="hr_recruitment_approval.group_hr_job_approver" class="oe_highlight"/>
                
                <button name="action_set_to_open" string="Publish &amp; Start" type="object"
                        invisible="state != 'final_stage'"
                        groups="hr_recruitment_approval.group_hr_job_approver" class="oe_highlight"/>
                
                <button name="action_refuse" string="Refuse" type="object"
                        invisible="state not in ['first_stage', 'second_stage', 'final_stage']"
                        groups="hr_recruitment_approval.group_hr_job_approver"/>
                
                <field name="state" widget="statusbar"
                       statusbar_visible="draft,first_stage,second_stage,final_stage,open"/>
            </xpath>

            <!-- 2. Helper Field (Invisible) -->
            <xpath expr="//sheet" position="inside">
                <field name="is_final_approver" invisible="1"/>
            </xpath>

            <!-- 3. Approver Management Section -->
            <xpath expr="//sheet" position="inside">
                <group string="Approver Management" name="approver_mgmt">
                    <group>
                        <field name="approver_stage_1" readonly="state != 'draft'"/>
                        <field name="approver_stage_2" readonly="state != 'draft'"/>
                        <field name="approver_final" readonly="state != 'draft'"/>
                    </group>
                </group>
            </xpath>

            <!-- 4. Security Logic for Website Publication -->
            <xpath expr="//field[@name='website_published']" position="attributes">
                <attribute name="readonly">not is_final_approver or state not in ['final_stage', 'open']</attribute>
                <attribute name="help">Only the designated Final Approver can modify publication status.</attribute>
            </xpath>

        </field>
    </record>
</odoo>

