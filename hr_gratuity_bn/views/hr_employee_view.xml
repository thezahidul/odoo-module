<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_form_gratuity_inherit" model="ir.ui.view">
        <field name="name">hr.employee.form.gratuity.inherit</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Gratuity (BD Law)" name="gratuity_details">
                    <field name="can_enable_gratuity" invisible="1"/>

                    <group string="HR Policy &amp; Eligibility">
                        <group>
                            <field name="is_gratuity_eligible" 
                                   widget="boolean_toggle" 
                                   readonly="not can_enable_gratuity"/>
                            <field name="min_service_years" invisible="not is_gratuity_eligible"/>
                        </group>
                        <group>
                            <field name="employee_type" readonly="1"/>
                            <field name="contract_type_id" readonly="1"/>
                        </group>
                    </group>

                    <group string="Service Information" invisible="not is_gratuity_eligible">
                        <group>
                            <field name="manual_joining_date" required="1"/>
                        </group>
                        <group>
                            <field name="manual_basic_salary" string="Last Drawn Basic" required="1"/>
                        </group>
                    </group>

                    <group string="Final Calculation" invisible="not is_gratuity_eligible">
                        <group>
                            <field name="gratuity_amount" readonly="1" decoration-bf="1" decoration-info="1"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>