<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_form_gratuity_inherit" model="ir.ui.view">
        <field name="name">hr.employee.form.gratuity.inherit</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Gratuity (BD Law)" name="gratuity_details">
                    <field name="can_enable_gratuity" invisible="1"/>

                    <group string="HR Policy &amp; Eligibility">
                        <group>
                            <field name="is_gratuity_eligible" 
                                   widget="boolean_toggle" 
                                   readonly="not can_enable_gratuity"
                                   help="Employee must to be Permanent or Full Time."/>
                            <field name="min_service_years" invisible="not is_gratuity_eligible"/>
                        </group>
                        <group>
                            <field name="employee_type" readonly="1"/>
                            <field name="contract_type_id" readonly="1"/>
                        </group>
                    </group>

                    <group string="Inherited System Data" invisible="not is_gratuity_eligible">
                        <group>
                            <field name="contract_date_start" readonly="1" string="Joining Date"/>
                            <field name="departure_date" readonly="1" string="Departure/Resign Date"/>
                        </group>
                        <group>
                            <field name="wage" readonly="1" string="Current Basic Wage"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>

                    <group string="Final Result" invisible="not is_gratuity_eligible">
                        <group>
                            <field name="gratuity_amount" readonly="1" decoration-bf="1" decoration-info="1" widget="monetary"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
