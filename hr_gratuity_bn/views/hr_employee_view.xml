<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_form_gratuity_inherit" model="ir.ui.view">
        <field name="name">hr.employee.form.gratuity.inherit</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Gratuity (BD Law)" name="gratuity_details">
                    <field name="can_enable_gratuity" invisible="1"/>

                    <group string="HR Policy &amp; Eligibility">
                        <group>
                            <field name="is_gratuity_eligible" widget="boolean_toggle" readonly="not can_enable_gratuity" help="Employee must be Permanent or Full Time."/>
                            <field name="min_service_years" invisible="not is_gratuity_eligible"/>
                        </group>
                        <group>
                            <field name="employee_type" readonly="1"/>
                            <field name="contract_type_id" readonly="1"/>
                        </group>
                    </group>

                    <group string="Inherited System Data" invisible="not is_gratuity_eligible">
                        <group>
                            <field name="contract_date_start" readonly="1" string="Joining Date"/>
                            <field name="departure_date" readonly="1" string="Departure/Resign Date"/>
                        </group>
                        <group>
                            <field name="wage" readonly="1" string="Current Gross Wage"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>

                    <group string="Tax Configuration" invisible="not is_gratuity_eligible">
                        <group>
                            <field name="is_nbr_approved" widget="boolean_toggle"/>
                            <field name="gratuity_exemption_limit" invisible="not is_nbr_approved"/>
                        </group>
                        <group>
                            <field name="gratuity_tax_percent"/>
                        </group>
                    </group>

                    <group string="Final Settlement" invisible="not is_gratuity_eligible">
                        <group>
                            <field name="gratuity_amount" string="Total Gross Gratuity" decoration-bf="1"/>
                            <field name="gratuity_taxable_amount" string="Taxable Portion" invisible="gratuity_taxable_amount == 0" decoration-warning="1"/>
                        </group>
                        <group>
                            <field name="gratuity_tax_amount" string="TDS (Tax)"/>
                            <field name="gratuity_net_payable" string="Net Payout" decoration-success="1" decoration-bf="1"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>